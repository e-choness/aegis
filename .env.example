# Copy to .env and fill in values

# Tier 1A: Anthropic
TIER_1A_ENABLED=true
ANTHROPIC_API_KEY=sk-ant-...

# Tier 1B: Azure OpenAI Canada
TIER_1B_ENABLED=true
AZURE_OPENAI_API_KEY=...
AZURE_OPENAI_BASE_URL=https://your-resource.openai.azure.com/

# Tier 2: External LLM Service
TIER_2_ENABLED=true
TIER_2_AUTH_TYPE=api_key
TIER_2_API_KEY=sk_...
TIER_2_CERT_PATH=/etc/aegis/client.crt
TIER_2_KEY_PATH=/etc/aegis/client.key
TIER_2_CA_PATH=/etc/aegis/ca.crt

# Tier 3: LangGraph
TIER_3_ENABLED=true
LANGGRAPH_API_URL=http://langgraph:8000

# Gateway
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
VECTORDB_URL=postgresql://...

# Infrastructure
GRAFANA_PASSWORD=admin
TIMESCALEDB_PASSWORD=aegis_dev