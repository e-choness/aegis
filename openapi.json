  "paths": {
    "/v1/audit": {
      "get": {
        "description": "Return run records matching the supplied filters.\n\nAll filters are optional and ANDed together.\n``since`` compares lexicographically against the ISO-8601 ``created_at``\nfield \u2014 works correctly for UTC timestamps.",
        "operationId": "audit_runs_v1_audit_get",
        "parameters": [
          {
            "description": "Filter by principal_id",
            "in": "query",
            "name": "principal",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Filter by principal_id",
              "title": "Principal"
            }
          },
          {
            "description": "Filter by route",
            "in": "query",
            "name": "route",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Filter by route",
              "title": "Route"
            }
          },
          {
            "description": "ISO-8601 lower bound on created_at",
            "in": "query",
            "name": "since",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "description": "ISO-8601 lower bound on created_at",
              "title": "Since"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": {
                    "items": {
                      "additionalProperties": true,
                      "type": "object"
                    },
                    "type": "array"
                  },
                  "title": "Response Audit Runs V1 Audit Get",
                  "type": "object"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Audit Runs"
      }
    },
