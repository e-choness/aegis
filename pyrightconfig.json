{
  "pythonVersion": "3.12",
  "pythonPlatform": "Linux",
  "venvPath": ".",
  "venv": ".venv",
  "typeCheckingMode": "standard",
  "reportMissingImports": true,
  "reportMissingTypeStubs": false,
  "include": [
    "packages",
    "sdk/python",
    "scripts"
  ],
  "exclude": [
    ".venv",
    "**/__pycache__",
    "**/*.egg-info",
    ".uv-cache"
  ]
}
